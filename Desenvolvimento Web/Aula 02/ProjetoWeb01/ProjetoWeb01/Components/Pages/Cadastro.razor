@page "/cadastro"
@using ProjetoWeb01.Classes.Entidades
@using ProjetoWeb01.Classes.Serv
@using ProjetoWeb01.Dados
@inject AlunoService alunoService
@inject NavigationManager navigationManager
@rendermode InteractiveServer

<div class="wrapper">
    <CabecalhoPagina/>
    <div class="cadastro-container">
    <h2 class="cadastro-cabecalho">
        Novo usuário
    </h2>
        @if (!string.IsNullOrEmpty(mensagem_de_Erro))
        {
            <div>@mensagem_de_Erro</div>
        }

        @if (!string.IsNullOrEmpty(mensagem_de_Sucesso))
        {
            <div>@mensagem_de_Sucesso</div>
        }


    <!-- Acionar evento 'submit' no código C# p/ capturar os dados -->
    <form class="cadastro-form" @onsubmit="CadastrarAluno">
        <div class="form-grupo">
            <label class="form-label">Nome do usuário</label>
            <input type="text" class="form-input" @bind="novoAluno.Nome"/>
        </div>
        <div class="form-grupo">
            <label class="form-label">RA</label>
            <input type="number" class="form-input" @bind="novoAluno.RA"/>
        </div>
        <div class="form-grupo">
            <label class="form-label">Curso</label>
            <select class="form-input" @bind="novoAluno.CursoID">
                <option value="">Selecione...</option>
                    @foreach (var cursoItem in curso.Curso)
                    {
                        <option value="@cursoItem.Key">@cursoItem.Value</option>
                    }
                </select>
        </div>
        <button type="submit" class="btn-cadastro">
            @(cadastrando ? "Cadastrando..." : "Cadastrar")
        </button>
    </form>

</div>
    <Rodape/>
</div>
@code {

    private Cursos curso = new Cursos();
    private Aluno novoAluno = new Aluno();
    private string mensagem_de_Erro = string.Empty;
    private string mensagem_de_Sucesso = string.Empty;
    private bool cadastrando = false;

    private async Task CadastrarAluno()
    {
        cadastrando = true;
        mensagem_de_Erro = string.Empty;
        mensagem_de_Sucesso = string.Empty;

        try
        {
            var resultado = await alunoService.CadastrarAluno(novoAluno);

            if (resultado.Sucesso)
            {
                mensagem_de_Sucesso = resultado.Mensagem;
                await Task.Delay(1000);
                navigationManager.NavigateTo("/listadeusuarios");
            }
            else
            {
                mensagem_de_Erro = resultado.Mensagem;
            }
        }
        finally
        {
            cadastrando = false;
        }
    }

    protected override void OnInitialized()
    {
        novoAluno = new Aluno();
    }

}
