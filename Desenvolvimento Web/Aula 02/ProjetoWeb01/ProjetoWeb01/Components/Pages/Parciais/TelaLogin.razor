@using System.ComponentModel.DataAnnotations
@using ProjetoWeb01.Classes.Entidades
@using ProjetoWeb01.Classes.Serv
@using ProjetoWeb01.Classes.Contratos
@inject AuthService authService
@inject NavigationManager navigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<main class="corpo-pagina">
    <!-- ================================================================== -->
    <!-- TELA 1: LOGIN -->
    <!-- ================================================================== -->
    <div id="tela-login" class="tela-de-login">
        <div class="login-container">
            <div class="login-header">
                <div class="login-icon-wrapper">
                    <i data-lucide="wifi" class="fa-solid fa-wifi"></i>
                </div>
                <h1 class="login-title">Acesso ao WI-FI</h1>
                <p class="login-subtitle">Sistema de Gestão Wi-Fi</p>
            </div>

            <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin" FormName="login-form">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(mensagemErro))
                {
                    <div class="alert alert-danger" style="margin-bottom: 1rem; padding: 0.75rem; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 0.25rem;">
                        @mensagemErro
                    </div>
                }

                <div class="form-group">
                    <label for="email" class="form-label">E-mail Institucional</label>
                    <div class="input-wrapper">
                        <div class="input-icon">
                            <i data-lucide="mail" class="h-5 w-5 text-gray-400"></i>
                        </div>
                        <InputText @bind-Value="loginModel.Email" id="email" class="form-input" placeholder="admin@senaisp.br" />
                    </div>
                    <ValidationMessage For="@(() => loginModel.Email)" />
                </div>

                <div class="form-group">
                    <label for="senha" class="form-label">Senha</label>
                    <div class="input-wrapper">
                        <div class="input-icon">
                            <i data-lucide="lock" class="h-5 w-5 text-gray-400"></i>
                        </div>
                        <InputText type="password" @bind-Value="loginModel.Senha" id="senha" class="form-input" placeholder="••••••••" />
                    </div>
                    <ValidationMessage For="@(() => loginModel.Senha)" />
                </div>

                <!-- Botão de Login -->
                <button type="submit" class="btn-login" disabled="@estaProcessando">
                    @if (estaProcessando)
                    {
                        <span>Processando...</span>
                    }
                    else
                    {
                        <span>Login</span>
                    }
                </button>
            </EditForm>

        </div>
    </div>
</main>

@code {
    private LoginModel loginModel = new();
    private string mensagemErro = string.Empty;
    private bool estaProcessando = false;

    private async Task HandleLogin()
    {
        estaProcessando = true;
        mensagemErro = string.Empty;

        try
        {
            var aluno = authService.ValidarLoginAsync(loginModel.Email, loginModel.Senha);
            if(aluno != null)
            {
                //Login bem-sucedido - redirecionar para a página externa
                await JSRuntime.InvokeVoidAsync("open", "https://www.sp.senai.br/unidade/americana/", "_self");
            }
            else
            {
                mensagemErro = "E-mail ou senha incorreta. Por favor, tente novamente";
            }
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro ao processar login {ex.Message}";
        }
        finally
        {
            estaProcessando = false;
        }
    }
}
